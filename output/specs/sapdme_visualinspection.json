{
  "openapi": "3.0.2",
  "info": {
    "title": "Visual Inspection",
    "description": "Use Visual Inspection to embed AI-assisted processes on your shop floor. The service enables you to efficiently manage visual inspection objects.",
    "version": "v1",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    }
  },
  "externalDocs": {
    "description": "Prepare for API Integration",
    "url": "https://help.sap.com/docs/sap-digital-manufacturing/operations-guide/prepare-for-api-integration"
  },
  "x-sap-api-type": "ODATAV4",
  "x-odata-version": "4.01",
  "x-sap-shortText": "Manage visual inspection objects to embed AI-assisted processes on your shop floor.",
  "servers": [
    {
      "url": "https://api.{regionHost}/visualinspection",
      "description": "Base URL",
      "variables": {
        "regionHost": {
          "description": "The data center where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.dmc.cloud.sap",
            "eu20.dmc.cloud.sap",
            "us10.dmc.cloud.sap",
            "us20.dmc.cloud.sap",
            "test.eu10.dmc.cloud.sap",
            "test.eu20.dmc.cloud.sap",
            "test.us10.dmc.cloud.sap",
            "test.us20.dmc.cloud.sap"
          ],
          "default": "test.eu10.dmc.cloud.sap"
        },
        "tokenHost": {
          "description": "The authentication server where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.hana.ondemand.com",
            "eu20.hana.ondemand.com",
            "us10.hana.ondemand.com",
            "us20.hana.ondemand.com"
          ],
          "default": "eu10.hana.ondemand.com"
        }
      }
    }
  ],
  "security": [
    {
      "OauthClientCredentials": []
    }
  ],
  "tags": [
    {
      "name": "Visual Inspections"
    }
  ],
  "paths": {
    "/v1/findVisualInspections()": {
      "get": {
        "summary": "Find visual inspections using the business context",
        "description": "Find visual inspections using the business context. The business context can be one or more of the business objects that visual inspections can be assigned to.",
        "operationId": "findVisualInspections",
        "tags": [
          "Visual Inspections"
        ],
        "parameters": [
          {
            "required": true,
            "in": "query",
            "name": "plant",
            "description": "The plant assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "material",
            "description": "The material assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "materialVersion",
            "description": "The version of the material assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "routing",
            "description": "The routing assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "routingType_code",
            "description": "The type of the routing assigned to the visual inspection",
            "schema": {
              "type": "string",
              "enum": [
                "PRODUCTION",
                "NC",
                "SPECIAL",
                "DISPOSITION_FUNCTION",
                "SFC_SPECIFIC",
                "SHOPORDER_SPECIFIC",
                "CONFIGURABLE",
                "PRODUCTION_RECIPE",
                "SHOPORDER_SPECIFIC_RECIPE"
              ]
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "routingVersion",
            "description": "The version of the routing assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "operation",
            "description": "The operation activity assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "operationVersion",
            "description": "The version of the operation activity assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "workCenter",
            "description": "The work center assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "resource",
            "description": "The resource assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "shopOrder",
            "description": "The order assigned to the visual inspection",
            "schema": {
              "type": "string"
            }
          },
          {
            "required": false,
            "in": "query",
            "name": "$expand",
            "description": "The value of $expand query option is a comma-separated list of navigation property names, stream property names, or $value indicating the stream content of a media-entity. The corresponding related entities and stream values will be represented inline, see [Expand](http://docs.oasis-open.org/odata/odata/v4.01/odata-v4.01-part1-protocol.html#sec_SystemQueryOptionexpand)",
            "example": "views($expand=view($expand=model))",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "Collection of Visual Inspections",
                  "properties": {
                    "@count": {
                      "$ref": "#/components/schemas/count"
                    },
                    "value": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/InspectionScenarios"
                      }
                    }
                  }
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/error"
          }
        }
      }
    }
  },
