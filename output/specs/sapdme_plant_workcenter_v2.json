  "info": {
    "description": "A Work Center can be a place or a machine or a labor where production operations/activities are performed. This API can be used to create, change, delete, and search for work centers and custom field definitions for it.",
    "version": "v2",
    "title": "Work Center",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    }
  },
  "host": "hostname",
  "basePath": "/",
  "tags": [
    {
      "name": "Work Center",
      "description": "Work Center Api V2 Controller"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "security": [
    {
      "OauthClientCredentials": []
    }
  ],
  "paths": {
    "/workcenters": {
      "get": {
        "tags": [
          "Work Center"
        ],
        "summary": "Searches for work centers by plant and work center values.",
        "description": "Searches for a work center for a given plant and returns the details for the same. This endpoint is now deprecated, please use the successor API <a href=https://api.sap.com/api/sapdme_plant_workcenter_v3/resource/readWorkCentersUsingGETV3>Get Work Centers</a>",
        "operationId": "readUsingGET",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "plant",
            "in": "query",
            "description": "The plant where a work center is defined.",
            "required": true,
            "type": "string",
            "pattern": "^(?! )[0-9A-Z_$!)(+~@^=\\-*. ]+(?<! )$"
          },
          {
            "name": "workCenter",
            "in": "query",
            "description": "The work center value.",
            "required": false,
            "type": "string",
            "pattern": "^(?! )[0-9A-Z_$!)(+~@^=\\-*. ]+(?<! )$"
          },
          {
            "name": "assignedUser",
            "in": "query",
            "description": "The user identifier.",
            "required": false,
            "type": "string",
            "pattern": "^(?! )[0-9A-Z_$!)(+~@^=\\-*. ]+(?<! )$"
          },
          {
            "name": "resourceMembers",
            "in": "query",
            "description": "The resource members.",
            "required": false,
            "type": "string",
            "pattern": "^(?! )[0-9A-Z_$!)(+~@^=\\-*. ]+(?<! )$"
          }
        ],
        "responses": {
          "200": {
            "description": "The work center was found.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/WorkCenterV2"
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "The plant was not found.",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "An internal error occured.",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        },
        "deprecated": true
      },
