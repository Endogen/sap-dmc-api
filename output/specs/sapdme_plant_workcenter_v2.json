          "type": "string"
        },
        "fieldLabel": {
          "description": "The custom field definition label.",
          "type": "string"
        },
        "sequence": {
          "description": "The custom field definition sequence.",
          "type": "number"
        },
        "createdDateTime": {
          "description": "The date and time when the custom field definition was created.",
