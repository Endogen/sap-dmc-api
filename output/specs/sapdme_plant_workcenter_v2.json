            }
          },
          "500": {
            "description": "An internal error occured.",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Work Center"
        ],
        "summary": "Updates the given work center.",
        "description": "Updates a work center for a given plant.",
        "operationId": "updateUsingPATCH",
