{
  "openapi": "3.0.1",
  "info": {
    "title": "Data Fields API",
    "description": "API for managing data fields in SAP Digital Manufacturing",
    "version": "v1",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    }
  },
  "x-sap-shortText": "Use this API to manage data fields in SAP Digital Manufacturing.",
  "externalDocs": {
    "description": "Prepare for API Integration",
    "url": "https://help.sap.com/docs/sap-digital-manufacturing/operations-guide/prepare-for-api-integration"
  },
  "servers": [
    {
      "url": "https://api.{regionHost}/dataField",
      "description": "Base URL",
      "variables": {
        "regionHost": {
          "description": "The data center where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.dmc.cloud.sap",
            "eu20.dmc.cloud.sap",
            "us10.dmc.cloud.sap",
            "us20.dmc.cloud.sap",
            "test.eu10.dmc.cloud.sap",
            "test.eu20.dmc.cloud.sap",
            "test.us10.dmc.cloud.sap",
            "test.us20.dmc.cloud.sap"
          ],
          "default": "test.eu10.dmc.cloud.sap"
        },
        "tokenHost": {
          "description": "The authentication server where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.hana.ondemand.com",
            "eu20.hana.ondemand.com",
            "us10.hana.ondemand.com",
            "us20.hana.ondemand.com"
          ],
          "default": "eu10.hana.ondemand.com"
        }
      }
    }
  ],
  "security": [
    {
      "OauthClientCredentials": []
    }
  ],
  "tags": [
    {
      "name": "Data Fields API",
      "description": "API for Data Field management operations"
    }
  ],
  "paths": {
    "/v1/dataFields": {
      "get": {
        "tags": [
          "Data Field API"
        ],
        "summary": "Gets paginated list of data fields by plant",
        "description": "Retrieves a paginated list of data fields for a specific plant",
        "operationId": "getDataFields",
        "parameters": [
          {
            "name": "plant",
            "in": "query",
            "description": "Plant identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fieldName",
            "in": "query",
            "description": "A field name identifier. Use this parameter to retrieve a specific data field. If the parameter is provided, sorting and pagination parameters are ignored.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "A zero-based page index (0..N)",
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "minimum": 0,
              "type": "integer",
              "default": 0
            }
          },
          {
            "description": "The size of the page to be returned. Maximum size - 50.",
            "in": "query",
            "name": "size",
            "required": false,
            "schema": {
              "minimum": 1,
              "maximum": 50,
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort criteria according to the format: property,(asc|desc). Multiple sort criteria are supported. Allowed sort fields: fieldName, fieldLabel, description, type, createdDateTime, modifiedDateTime.",
            "example": "sort=createdDateTime,desc",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [
                "fieldName,asc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message processed successfully. The system returns a pageable collection when the fieldName is not provided, or a single data field when the fieldName is specified.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageDataFieldResponse"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "Client error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Data Field API"
        ],
        "summary": "Creates a list of data fields",
        "description": "Creates multiple data field objects",
        "operationId": "createDataFields",
        "requestBody": {
          "description": "A list of data fields to create",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DataFieldRequest"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Data fields were created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataFieldResponse"
                  }
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "A client error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Data Field API"
        ],
        "summary": "Updates a list of data fields",
        "description": "Updates multiple data field objects. Only provided fields are updated.",
        "operationId": "updateDataFields",
        "requestBody": {
          "description": "A list of data fields to update",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DataFieldRequest"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data fields were updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataFieldResponse"
                  }
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "A client error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Data Field API"
        ],
        "summary": "Deletes a data field by plant and field name",
        "description": "Removes a data field by its plant and field name",
        "operationId": "deleteDataField",
        "parameters": [
          {
            "name": "fieldName",
            "in": "query",
            "description": "A field name identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "plant",
            "in": "query",
            "description": "Plant identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Data field deleted successfully."
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "4XX": {
            "description": "A client error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DataFieldRequest": {
        "type": "object",
        "required": [
          "plant",
          "fieldName",
          "type"
        ],
        "properties": {
          "plant": {
            "type": "string",
            "description": "Plant identifier",
            "example": "PLANT_001"
          },
          "fieldName": {
            "type": "string",
            "description": "Unique field name",
            "example": "COLOR_FIELD"
          },
          "fieldLabel": {
            "type": "string",
            "description": "Field label",
            "example": "Color Field"
          },
          "description": {
            "type": "string",
            "description": "Field description",
            "example": "A custom field for tracking label colors."
          },
          "browsable": {
            "type": "boolean",
            "example": false,
            "description": "Indicates if the data field is browsable. Always false for not preloaded fields."
          },
          "type": {
            "type": "string",
            "description": "Field type",
            "enum": [
              "TEXT",
              "TEXT_AREA",
              "DATE",
              "NUMBER",
              "CHECKBOX",
              "LIST",
              "FORMULA"
            ],
            "example": "LIST"
          },
          "dataFieldOptions": {
            "type": "array",
            "description": "A list of options for data fields of the LIST type. It is empty for other data field types.",
            "items": {
              "$ref": "#/components/schemas/DataFieldOption"
            },
            "example": [
              {
                "fieldValue": "RED",
                "optionLabel": "Red Color",
                "isDefault": true
              },
              {
                "fieldValue": "BLUE",
                "optionLabel": "Blue Color",
                "isDefault": false
              },
              {
                "fieldValue": "GREEN",
                "optionLabel": "Green Color",
                "isDefault": false
              },
              {
                "fieldValue": "YELLOW",
                "optionLabel": "Yellow Color",
                "isDefault": false
              }
            ]
          }
        }
      },
      "DataFieldResponse": {
        "type": "object",
        "properties": {
          "plant": {
            "type": "string",
            "description": "The plant of the data field"
          },
          "fieldName": {
            "type": "string",
            "description": "The name of the data field"
          },
          "fieldLabel": {
            "type": "string",
            "description": "The label of the data field"
          },
          "description": {
            "type": "string",
            "description": "The description of the data field"
          },
          "type": {
            "type": "string",
            "enum": [
              "TEXT",
              "TEXT_AREA",
              "DATE",
              "NUMBER",
              "CHECKBOX",
              "LIST",
              "FORMULA"
            ],
            "example": "LIST",
            "description": "The type of the data field"
          },
          "browsable": {
            "type": "boolean",
            "example": false,
            "description": "Indicates if the data field is browsable. Always false for not built-in fields."
          },
          "dataFieldOptions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataFieldOption"
            }
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time",
            "example": "2025-12-04T10:30:00Z",
            "description": "The date and time when the data field was created"
          },
          "modifiedDateTime": {
            "type": "string",
            "format": "date-time",
            "example": "2025-12-04T15:45:00Z",
            "description": "The date and time when the data field was last modified"
          }
        }
      },
      "DataFieldOption": {
        "type": "object",
        "required": [
          "fieldValue",
          "isDefault"
        ],
        "properties": {
          "fieldValue": {
            "type": "string",
            "example": "Color",
            "description": "The value of the option. It must be unique within the data field options list."
          },
          "optionLabel": {
            "type": "string",
            "example": "Label Color",
            "description": "The label for the option. If not provided, the fieldValue will be used as the label."
          },
          "isDefault": {
            "type": "boolean",
            "example": false,
            "description": "Indicates if this option is the default. There can be only one default option in the data field options list."
          }
        }
      },
      "PageDataFieldResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataFieldResponse"
            }
          },
          "pageable": {
            "$ref": "#/components/schemas/PageableObject"
          },
          "last": {
            "type": "boolean",
            "description": "True if it is the last page"
          },
          "totalElements": {
            "type": "integer",
            "format": "int64",
            "example": 100,
            "description": "The total number of records that are retrieved"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32",
            "example": 5,
            "description": "The total number of pages returned"
          },
          "size": {
            "type": "integer",
            "format": "int32",
            "example": 20
          },
          "number": {
            "type": "integer",
            "format": "int32",
            "example": 0,
            "description": "The page number"
          },
          "sort": {
            "$ref": "#/components/schemas/SortObject"
          },
          "first": {
            "type": "boolean",
            "description": "True if it is the first page"
          },
          "numberOfElements": {
            "type": "integer",
            "example": 20,
            "format": "int32",
            "description": "The number of elements in the current page"
          },
          "empty": {
            "type": "boolean",
            "description": "Returns true if the result is empty"
          }
        }
      },
      "ErrorResponse": {
        "title": "ErrorResponse",
        "type": "object",
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorResponseApiModel"
          }
        }
      },
      "ErrorResponseApiModel": {
        "title": "ErrorResponseApiModel",
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Contains a technical code for the error."
          },
          "correlationId": {
            "type": "string",
            "description": "Contains a correlation ID for the error."
          },
          "message": {
            "type": "string",
            "description": "Error message."
          },
          "details": {
            "type": "array",
            "description": "Error message details.",
            "items": {
              "$ref": "#/components/schemas/ErrorDetail"
            }
          }
        },
        "description": "Error response."
      },
      "ErrorDetail": {
        "title": "ErrorDetail",
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Contains a technical code for the error."
          },
          "message": {
            "type": "string",
            "description": "Contains a detailed message for the error."
          }
        },
        "description": "Error detail."
      },
      "PageableObject": {
        "type": "object",
        "properties": {
          "pageNumber": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "sort": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SortObject"
            }
          },
          "offset": {
            "type": "integer",
            "format": "int64"
          },
          "paged": {
            "type": "boolean"
          },
          "unpaged": {
            "type": "boolean"
          }
        }
      },
      "SortObject": {
        "type": "object",
        "properties": {
          "direction": {
            "type": "string"
          },
          "property": {
            "type": "string"
          },
          "ignoreCase": {
            "type": "boolean"
          },
          "nullHandling": {
            "type": "string"
          },
          "descending": {
            "type": "boolean"
          },
          "ascending": {
            "type": "boolean"
          }
        }
      }
    },
    "responses": {
      "error": {
        "description": "Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "OauthClientCredentials": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{subdomain}.authentication.{tokenHost}/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  }
}