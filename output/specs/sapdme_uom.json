    "ErrorResponseApiModelV2": {
      "title": "ErrorResponseApiModel",
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "Contains a technical code for the error."
        },
        "correlationId": {
          "type": "string",
          "description": "Contains a correlation ID for the error."
        },
        "message": {
          "type": "string",
          "description": "Error message."
        },
        "details": {
          "type": "array",
          "description": "Error message details.",
          "items": {
            "$ref": "#/definitions/ErrorDetailV2"
          }
        }
      },
      "description": "Error response."
    },
    "ErrorDetailV2": {
      "title": "ErrorDetail",
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "Contains a technical code for the error."
        },
        "message": {
          "type": "string",
          "description": "Contains a detailed message for the error."
        }
      },
      "description": "Error detail."
    }
  },
