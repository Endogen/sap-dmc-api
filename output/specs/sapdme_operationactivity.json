{
  "openapi": "3.0.1",
  "info": {
    "title": "Operation Activity",
    "description": "You use this API to define operation activities that will be associated with a routing. You can create and update operation activities with custom data values, find operation activities according to search criteria and delete operation activities.",
    "version": "v1",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    }
  },
  "externalDocs": {
    "description": "Prepare for API Integration",
    "url": "https://help.sap.com/docs/sap-digital-manufacturing/operations-guide/prepare-for-api-integration"
  },
  "x-sap-shortText": "Operation activities associated with a routing.",
  "servers": [
    {
      "url": "https://api.{regionHost}/operationActivity/v1",
      "description": "Base URL",
      "variables": {
        "regionHost": {
          "description": "The data center where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.dmc.cloud.sap",
            "eu20.dmc.cloud.sap",
            "us10.dmc.cloud.sap",
            "us20.dmc.cloud.sap",
            "test.eu10.dmc.cloud.sap",
            "test.eu20.dmc.cloud.sap",
            "test.us10.dmc.cloud.sap",
            "test.us20.dmc.cloud.sap"
          ],
          "default": "test.eu10.dmc.cloud.sap"
        },
        "tokenHost": {
          "description": "The authentication server where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.hana.ondemand.com",
            "eu20.hana.ondemand.com",
            "us10.hana.ondemand.com",
            "us20.hana.ondemand.com"
          ],
          "default": "eu10.hana.ondemand.com"
        }
      }
    }
  ],
  "security": [
    {
      "OAuthSecurity": []
    }
  ],
  "tags": [
    {
      "name": "Operation Activity",
      "description": "Operation Activity CRUD API"
    }
  ],
  "paths": {
    "/operationActivities": {
      "get": {
        "tags": [
          "Operation Activity"
        ],
        "summary": "Finds list of operation activities.",
        "description": "Finds a list operation activities by plant and other optional criteria.",
        "operationId": "read",
        "parameters": [
          {
            "name": "plant",
            "in": "query",
            "description": "plant",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "operation",
            "in": "query",
            "description": "operation",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "description": "version",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "type",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "NORMAL_OPERATION",
                "SPECIAL_OPERATION"
              ]
            }
          },
          {
            "name": "currentVersion",
            "in": "query",
            "description": "current version flag",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "resourceType",
            "in": "query",
            "description": "resource type",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/ResourceTypeId"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "status",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "NEW",
                "RELEASABLE",
                "OBSOLETE",
                "HOLD"
              ]
            }
          },
          {
            "name": "pageable",
            "in": "query",
            "description": "Pagination parameters",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/Pageable"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The message was successfully processed.",
            "content": {
              "application/hal+json": {
                "schema": {
                  "$ref": "#/components/schemas/PageOperationActivityResponse"
                }
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "404": {
            "description": "One of the related elements is not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Operation Activity"
        ],
        "summary": "Creates a list of operation activities.",
        "description": "Creates a list of operation activities with specified properties. In case operation type is not specified it is defaulted to NORMAL_OPERATION.",
        "operationId": "create",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "description": "A list of operation activities to create",
                "items": {
                  "$ref": "#/components/schemas/OperationActivityCreateRequest"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Message successfully processed.",
            "content": {
              "application/hal+json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OperationActivityResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "404": {
            "description": "One of the related elements is not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "409": {
            "description": "One of the operation activities already exists.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Operation Activity"
        ],
        "summary": "Updates a list of operation activities.",
        "description": "Every operation activity that will be updated must have the plant, operation, and version fields specified. Only the specified fields will be updated. Any unspecified fields will remain unchanged.",
        "operationId": "updateProperties",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "description": "List of operation activities to update",
                "items": {
                  "$ref": "#/components/schemas/OperationActivityUpdateRequest"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The message was successfully processed.",
            "content": {
              "application/hal+json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OperationActivityResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "404": {
            "description": "One of the related elements is not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Operation Activity"
        ],
        "summary": "Deletes an operation activity.",
        "description": "Deletes an operation activity by plant, name, and version.",
        "operationId": "delete",
        "parameters": [
          {
            "name": "plant",
            "in": "query",
            "description": "plant",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "operation",
            "in": "query",
            "description": "operation",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "description": "version",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Operation activity deleted successfully."
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "404": {
            "description": "One of the related elements is not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CustomValue": {
        "required": [
          "attribute"
        ],
        "type": "object",
        "properties": {
          "attribute": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "RoutingId": {
        "type": "object",
        "properties": {
          "plant": {
            "type": "string"
          },
          "routing": {
            "type": "string"
          },
          "routingType": {
            "type": "string",
            "enum": [
              "PRODUCTION",
              "NC",
              "SPECIAL",
              "DISPOSITION",
              "SFC",
              "SHOP_ORDER",
              "CONFIGURABLE",
              "PRODUCTION_RECIPE",
              "SHOPORDER_SPECIFIC_RECIPE"
            ]
          },
          "version": {
            "type": "string"
          }
        }
      },
      "WorkCenterId": {
        "type": "object",
        "properties": {
          "workCenter": {
            "type": "string"
          }
        }
      },
      "ResourceTypeId": {
        "type": "object",
        "properties": {
          "resourceType": {
            "type": "string"
          }
        }
      },
      "ResourceId": {
        "type": "object",
        "properties": {
          "resource": {
            "type": "string"
          }
        }
      },
      "OperationActivityCreateRequest": {
        "type": "object",
        "required": [
          "plant",
          "operation",
          "version",
          "resourceType"
        ],
        "properties": {
          "plant": {
            "type": "string",
            "description": "The plant this operation is assigned to."
          },
          "operation": {
            "type": "string",
            "description": "Name of the operation."
          },
          "version": {
            "type": "string",
            "description": "The operation version."
          },
          "resourceType": {
            "$ref": "#/components/schemas/ResourceTypeId"
          },
          "resource": {
            "$ref": "#/components/schemas/ResourceId"
          },
          "workCenter": {
            "$ref": "#/components/schemas/WorkCenterId"
          },
          "type": {
            "type": "string",
            "description": "Indicates the type of operation.",
            "enum": [
              "NORMAL_OPERATION",
              "SPECIAL_OPERATION"
            ]
          },
          "description": {
            "type": "string",
            "description": "The description of the operation."
          },
          "currentVersion": {
            "type": "boolean",
            "description": "If true, then this is a current version of operation."
          },
          "status": {
            "type": "string",
            "description": "The status of the operation.",
            "enum": [
              "NEW",
              "RELEASABLE",
              "OBSOLETE",
              "HOLD"
            ]
          },
          "customValues": {
            "type": "array",
            "description": "Custom values of the operation.",
            "items": {
              "$ref": "#/components/schemas/CustomValue"
            }
          },
          "requiredTimeInProcess": {
            "type": "integer",
            "description": "The required time in process of this operation.",
            "format": "int32"
          }
        }
      },
      "OperationActivityUpdateRequest": {
        "type": "object",
        "properties": {
          "plant": {
            "type": "string",
            "description": "The plant this operation is assigned to."
          },
          "operation": {
            "type": "string",
            "description": "The name of the operation."
          },
          "version": {
            "type": "string",
            "description": "The operation version."
          },
          "resourceType": {
            "$ref": "#/components/schemas/ResourceTypeId"
          },
          "resource": {
            "$ref": "#/components/schemas/ResourceId"
          },
          "workCenter": {
            "$ref": "#/components/schemas/WorkCenterId"
          },
          "type": {
            "type": "string",
            "description": "Indicates the type of operation.",
            "enum": [
              "NORMAL_OPERATION",
              "SPECIAL_OPERATION"
            ]
          },
          "description": {
            "type": "string",
            "description": "The description of the operation."
          },
          "currentVersion": {
            "type": "boolean",
            "description": "If true, then this is a current version of the operation."
          },
          "status": {
            "type": "string",
            "description": "The status of the operation.",
            "enum": [
              "NEW",
              "RELEASABLE",
              "OBSOLETE",
              "HOLD"
            ]
          },
          "customValues": {
            "type": "array",
            "description": "Custom values of the operation.",
            "items": {
              "$ref": "#/components/schemas/CustomValue"
            }
          },
          "requiredTimeInProcess": {
            "type": "integer",
            "description": "The required time in process of this operation.",
            "format": "int32"
          }
        }
      },
      "error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Contains additional information if any."
          },
          "code": {
            "type": "string",
            "description": "Internal error message."
          },
          "causeMessage": {
            "type": "string",
            "description": "Contains a technical reason for the error."
          },
          "correlationId": {
            "type": "string",
            "description": "Contains a correlation ID for the error."
          }
        },
        "description": "Error response"
      },
      "OperationActivityResponse": {
        "type": "object",
        "properties": {
          "plant": {
            "type": "string",
            "description": "The plant this operation is assigned to."
          },
          "operation": {
            "type": "string",
            "description": "The name of the operation."
          },
          "version": {
            "type": "string",
            "description": "The operation version."
          },
          "resourceType": {
            "$ref": "#/components/schemas/ResourceTypeId"
          },
          "resource": {
            "$ref": "#/components/schemas/ResourceId"
          },
          "workCenter": {
            "$ref": "#/components/schemas/WorkCenterId"
          },
          "type": {
            "type": "string",
            "description": "Indicates the type of the operation.",
            "enum": [
              "NORMAL_OPERATION",
              "SPECIAL_OPERATION"
            ]
          },
          "specialRouting": {
            "$ref": "#/components/schemas/RoutingId"
          },
          "description": {
            "type": "string",
            "description": "The description of the operation."
          },
          "currentVersion": {
            "type": "boolean",
            "description": "If true, then this is a current version of the operation."
          },
          "status": {
            "type": "string",
            "description": "The status of the operation.",
            "enum": [
              "NEW",
              "RELEASABLE",
              "OBSOLETE",
              "HOLD"
            ]
          },
          "customValues": {
            "type": "array",
            "description": "Custom values of the operation.",
            "items": {
              "$ref": "#/components/schemas/CustomValue"
            }
          },
          "requiredTimeInProcess": {
            "type": "integer",
            "description": "The required time in process of this operation.",
            "format": "int32"
          },
          "createdDateTime": {
            "type": "string",
            "description": "The time when the operation activity was created.",
            "format": "date-time",
            "readOnly": true,
            "example": "2018-06-22T04:24:00.123Z"
          },
          "modifiedDateTime": {
            "type": "string",
            "description": "The time when the operation activity has most recently changed.",
            "format": "date-time",
            "readOnly": true,
            "example": "2018-06-22T04:24:00.123Z"
          }
        }
      },
      "Pageable": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "sort": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "PageOperationActivityResponse": {
        "type": "object",
        "properties": {
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "totalElements": {
            "type": "integer",
            "format": "int64"
          },
          "sort": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SortObject"
            },
            "description": "Defines how the operation records are sorted"
          },
          "number": {
            "type": "integer",
            "format": "int32"
          },
          "first": {
            "type": "boolean"
          },
          "last": {
            "type": "boolean"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OperationActivityResponse"
            }
          },
          "pageable": {
            "$ref": "#/components/schemas/PageableObject"
          },
          "numberOfElements": {
            "type": "integer",
            "format": "int32"
          },
          "empty": {
            "type": "boolean"
          }
        }
      },
      "PageableObject": {
        "type": "object",
        "properties": {
          "sort": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SortObject"
            },
            "description": "Defines how the operation records are sorted"
          },
          "offset": {
            "type": "integer",
            "format": "int64"
          },
          "pageNumber": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "paged": {
            "type": "boolean"
          },
          "unpaged": {
            "type": "boolean"
          }
        }
      },
      "SortObject": {
        "type": "object",
        "properties": {
          "empty": {
            "type": "boolean"
          },
          "unsorted": {
            "type": "boolean"
          },
          "sorted": {
            "type": "boolean"
          }
        }
      }
    },
    "securitySchemes": {
      "OAuthSecurity": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{subdomain}.authentication.{tokenHost}/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  }
}