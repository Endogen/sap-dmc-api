          },
          "resourceType": {
            "type": "string",
            "description": "Specifies the resource type."
          },
          "routerBO": {
            "type": "string",
            "description": "Specifies the router."
          },
          "sequence": {
            "type": "string",
            "description": "Specifies the sequence."
          },
          "setupTimeUom": {
            "type": "string",
            "description": "Specifies the setup time UOM."
          },
          "shopOrder": {
            "type": "string",
            "description": "Specifies the shop order."
          },
          "splitQuantity": {
            "type": "integer",
            "format": "int32",
            "description": "Specifies the split quantity."
          },
          "startDateTime": {
            "type": "string",
            "description": "Specifies the start date and time. Format(YYYY-MM-DDThh:mm:ssZ)."
          },
          "tearDownTimeUom": {
            "type": "string",
            "description": "Specifies the teardown time UOM."
          },
          "unitOfMeasure": {
            "type": "string",
            "description": "Specifies the unit of measure."
          }
        },
        "title": "ShopOrderSchedule"
      },
      "ShopOrderScheduleRequest": {
        "type": "object",
        "required": [
          "endDateTime",
          "plant",
          "startDateTime",
          "user"
        ],
        "properties": {
          "endDateTime": {
            "type": "string",
            "description": "The horizon end date and time till when shop order schedules needs to be fetched in UTC. Format(YYYY-MM-DDThh:mm:ssZ)."
          },
          "plant": {
            "type": "string",
            "description": "The plant for which the request is executed."
          },
          "startDateTime": {
            "type": "string",
            "description": "The horizon start date and time from when the shop order schedules needs to be fetched in UTC. Format(YYYY-MM-DDThh:mm:ssZ)."
          },
          "user": {
            "type": "string",
            "description": "The ID of the user for which shop order schedules needs to be fetched."
          }
        },
        "title": "ShopOrderScheduleRequest"
      },
      "ScheduleOrderRequest": {
        "type": "object",
        "required": [
          "startDateTime",
          "endDateTime",
          "plant",
          "user",
          "shopOrder"
        ],
        "properties": {
          "startDateTime": {
            "type": "string",
            "description": "The horizon start date and time from which the shop order schedules need to be scheduled. The format should be in UTC and follow the format (YYYY-MM-DDThh:mm:ssZ)."
          },
          "endDateTime": {
            "type": "string",
            "description": "The horizon end date and time until which the shop order schedules need to be scheduled. The format should be in UTC and follow the format (YYYY-MM-DDThh:mm:ssZ)."
          },
          "plant": {
            "type": "string",
            "description": "The plant for which the request is being executed."
          },
          "user": {
            "type": "string",
            "description": "The user ID for retrieving the order schedules."
          },
          "order": {
            "type": "string",
            "description": "The order that needs to be scheduled."
          },
          "mode": {
            "type": "string",
            "description": "The mode that the order needs to be scheduled.(INFINITE,FINDSLOT)",
            "default": "INFINITE"
          }
        },
        "title": "ScheduleOrderRequest"
      },
      "OrderReschedule": {
        "type": "object",
        "required": [
          "plant",
          "order"
        ],
        "properties": {
          "dateTime": {
            "type": "string",
            "description": "The start date and time for which the order needs to be rescheduled. The format should be in UTC and follow the format is YYYY-MM-DDThh:mm:ssZ."
          },
          "resource": {
            "type": "string",
            "description": "The resource on which operation needs to be scheduled. If this is not available, the next suitable resource will be chosen."
          },
          "plant": {
            "type": "string",
            "description": "The plant for which the request is being executed."
          },
          "operation": {
            "type": "string",
            "description": "The operation that needs to be rescheduled. If this is not specified, the first operation will be chosen."
          },
          "order": {
            "type": "string",
            "description": "The order that needs to be scheduled."
          },
          "includeShiftBreaks": {
            "type": "boolean",
            "description": "Shift breaks to be considered."
          },
          "mode": {
            "type": "string",
            "description": "The mode that the order needs to be scheduled.(INFINITE,FINDSLOT)",
            "default": "INFINITE"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Specifies status of shoporder, 'successfully scheduled' or 'failed to schedule'"
          }
        },
        "title": "SuccessResponse",
        "description": "Success Response"
      }
    },
    "securitySchemes": {
      "OauthClientCredentials": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{subdomain}.authentication.{tokenHost}/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  },
