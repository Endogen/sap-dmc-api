  "components": {
    "schemas": {
      "CreateEBRPublicAPIRequest": {
        "type": "object",
        "required": [
          "plant",
          "order",
          "material",
          "materialVersion",
          "batch"
        ],
        "properties": {
          "plant": {
            "type": "string",
            "description": "The plant where the material is being produced.",
            "minLength": 1,
            "maxLength": 6
          },
          "order": {
            "description": "The order that the electronic batch record is associated with.",
            "type": "string"
          },
          "material": {
            "description": "The material that the order execution is producing.",
            "type": "string"
          },
          "materialVersion": {
            "description": "The version of the material that the order execution is producing.",
            "type": "string"
          },
          "batch": {
            "description": "The batch against which the goods receipt for the order is posted.",
            "type": "string"
          },
          "comment": {
            "description": "Comment while creating the electronic batch record.",
            "type": "string"
          }
        },
        "title": "CreateEBRRequest",
        "description": "Request to create an electronic batch record."
      },
      "CreateEBRPublicAPIResponse": {
        "type": "object",
        "title": "CreateEBRResponse",
        "description": "Create electronic batch record response.",
        "properties": {
          "ebrId": {
            "description": "ID of the electronic batch record.",
            "type": "string"
          },
          "version": {
            "description": "Version of the electronic batch record.",
            "type": "string"
          }
        }
      },
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "description": "Contains multiple errors."
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Internal error message."
          },
          "correlationId": {
            "type": "string",
            "description": "Contains the correlation ID for the error."
          },
          "message": {
            "type": "string",
            "description": "Contains any additional information."
          },
          "details": {
            "type": "array",
            "description": "Contains multiple errors.",
            "items": {
              "$ref": "#/components/schemas/ErrorDetail"
            }
          }
        },
        "title": "ErrorResponse",
        "description": "Error response."
      }
    },
    "securitySchemes": {
      "OauthClientCredentials": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{subdomain}.authentication.{tokenHost}/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "externalDocs": {
    "description": "Prepare for API Integration",
