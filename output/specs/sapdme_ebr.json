{
  "openapi": "3.0.3",
  "info": {
    "title": "Electronic Batch Record",
    "description": "This API allows you to create an electronic batch record for a batch and order used for producing a material.",
    "version": "Beta",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    }
  },
  "x-sap-stateInfo": {
    "state": "Beta"
  },
  "tags": [
    {
      "name": "Electronic Batch Record",
      "description": "Allows you to create an electronic batch record."
    }
  ],
  "paths": {
    "/ebrs": {
      "post": {
        "tags": [
          "Create Electronic Batch Record"
        ],
        "summary": "Create Electronic Batch Record",
        "description": "Allows you to create an electronic batch record for a batch and order used for producing a material.",
        "requestBody": {
          "description": "Request to create the electronic batch record.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEBRPublicAPIRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "CREATED",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateEBRPublicAPIResponse"
                }
              }
            }
          },
