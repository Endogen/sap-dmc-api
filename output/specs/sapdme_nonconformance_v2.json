{
  "openapi": "3.0.1",
  "info": {
    "title": "Nonconformance",
    "description": "In a manufacturing process, product defects are often found as part of quality checks. Use this service to retrieve logged nonconformances and check for open nonconformances.",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    },
    "version": "v2"
  },
  "externalDocs": {
    "description": "Prepare for API Integration",
    "url": "https://help.sap.com/docs/sap-digital-manufacturing/operations-guide/prepare-for-api-integration"
  },
  "servers": [
    {
      "url": "https://api.{regionHost}/nonconformance/v2",
      "description": "Base URL",
      "variables": {
        "regionHost": {
          "description": "The data center where SAP Digital Manufacturing is provisioned for your organization.",
          "enum": [
            "eu10.dmc.cloud.sap",
            "us10.dmc.cloud.sap",
            "eu20.dmc.cloud.sap",
            "us20.dmc.cloud.sap",
            "test.eu10.dmc.cloud.sap",
            "test.us10.dmc.cloud.sap",
            "test.eu20.dmc.cloud.sap",
            "test.us20.dmc.cloud.sap"
          ],
          "default": "test.eu10.dmc.cloud.sap"
        },
        "tokenHost": {
          "description": "The authentication token server where SAP Digital Manufacturing is provisioned for your organization.",
          "enum": [
            "eu10.hana.ondemand.com",
            "us10.hana.ondemand.com",
            "eu20.hana.ondemand.com",
            "us20.hana.ondemand.com"
          ],
          "default": "eu10.hana.ondemand.com"
        }
      }
    }
  ],
  "security": [
    {
      "OauthClientCredentials": []
    }
  ],
  "tags": [
    {
      "name": "Nonconformance",
      "description": "Non Conformance Api Controller"
    }
  ],
  "paths": {
    "/nonconformances": {
      "get": {
        "tags": [
          "Nonconformance"
        ],
        "summary": "Retrieves a list of nonconformances.",
        "description": "Retrieves a list of nonconformances for a given plant by various optional parameters.",
        "operationId": "getNonConformancesUsingGET_2",
        "parameters": [
          {
            "name": "operationActivity",
            "in": "query",
            "description": "The operation activity with the current version to search for nonconformances.",
            "schema": {
              "maxLength": 36,
              "minLength": 1,
              "type": "string"
            }
          },
          {
            "name": "plant",
            "in": "query",
            "description": "The plant to search for nonconformances.",
            "required": true,
            "schema": {
              "maxLength": 6,
              "minLength": 1,
              "type": "string"
            }
          },
          {
            "name": "resource",
            "in": "query",
            "description": "The resource to search for nonconformances.",
            "schema": {
              "maxLength": 36,
              "minLength": 1,
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "query",
            "description": "The ID of the nonconformance incident.",
            "schema": {
              "maxLength": 412,
              "minLength": 1,
              "type": "string"
            }
          },
          {
            "name": "routing",
            "in": "query",
            "description": "The routing with the current version to search for nonconformances.",
            "schema": {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            }
          },
          {
            "name": "routingStepId",
            "in": "query",
            "description": "The routing step to search for nonconformances.",
            "schema": {
              "maxLength": 20,
              "minLength": 1,
              "type": "string"
            }
          },
          {
            "name": "sfc",
            "in": "query",
            "description": "The SFC to search for nonconformances.",
            "schema": {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            }
          },
          {
            "name": "fromDate",
            "in": "query",
            "description": "The date and time to only show nonconformances logged after or at the given time stamp in UTC.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "toDate",
            "in": "query",
            "description": "The date and time to only show nonconformances logged before or at the given time stamp in UTC.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The page of nonconformances. By default,  the system returns the first page.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "The size of the nonconformance page. By default, the page size is 20 records. The maximum page size is 1000.)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "The retrieved records can be sorted using one or more of the following fields: 'id', 'state', 'createdDateTime'. Example: 'https://xxx?xxxx&sort=id,desc&sort=createdDateTime,desc' (By default the result sorted by logged date) ",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Page of Logged nonconformances.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pageable_NonConformance"
                }
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "404": {
            "description": "One of the related elements is not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": [
          {
            "OauthClientCredentials": []
          }
        ]
      }
    },
    "/checkForOpen": {
      "post": {
        "tags": [
          "Nonconformance"
        ],
        "summary": "Check for open nonconformances V2",
        "description": "Check for open nonconformance V2 by the given SFCs.",
        "operationId": "checkForOpenNonConformancesV2UsingPOST",
        "requestBody": {
          "description": "request",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckOpenNonConformancesV2Request"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "List of SFCs with open nonconformances.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CheckOpenNonConformanceBySfcV2Response"
                  }
                }
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error"
                }
              }
            }
          },
          "401": {
