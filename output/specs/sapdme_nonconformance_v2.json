  "components": {
    "schemas": {
      "DataField": {
        "title": "DataField",
        "type": "object",
        "properties": {
          "key": {
            "maxLength": 60,
            "minLength": 1,
            "type": "string",
            "description": "The name the data field."
          },
          "value": {
            "maxLength": 1024,
            "minLength": 1,
            "type": "string",
            "description": "The value of the data field."
          }
        },
        "description": "Name/value pair to be collected as part of logging a Non Conformance."
      },
      "IncidentNumber": {
        "title": "IncidentNumber",
        "type": "object",
        "properties": {
          "createdDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "incidentNumber": {
            "type": "string"
          },
          "modifiedDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "plant": {
            "type": "string"
          }
        }
      },
      "CheckOpenNonConformancesV2Request": {
        "title": "CheckOpenNonConformancesV2Request",
        "required": [
          "plant",
          "sfcs"
        ],
        "type": "object",
        "properties": {
          "sfcs": {
            "type": "array",
            "description": "The SFC to check for open nonconformances.",
            "items": {
              "type": "string"
            }
          },
          "plant": {
            "type": "string",
            "description": "The plant at which nonconformances are checked."
          },
          "ncCode": {
            "type": "string",
            "description": "The name of the nonconformance code at which nonconformances are checked."
          },
          "workCenter": {
            "type": "string",
            "description": "The name of the work center at which nonconformances are checked."
          },
          "resource": {
            "type": "string",
            "description": "The name of the resource at which nonconformances are checked."
          },
          "operationActivity": {
            "type": "string",
            "description": "The name of the operation activity at which nonconformances are checked."
          }
        },
        "description": "The request to check for open nonconformances (version 2)."
      },
      "Material": {
        "title": "Material",
        "type": "object",
        "properties": {
          "material": {
            "type": "string"
          },
          "plant": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "CheckOpenNonConformanceBySfcV2Response": {
        "title": "CheckOpenNonConformanceBySfcV2Response",
        "type": "object",
        "properties": {
          "sfc": {
            "type": "string",
            "description": "The SFC with open nonconformances."
          },
          "openNcs": {
            "type": "array",
            "description": "The list of open nonconformance codes and incident IDs.",
            "items": {
              "$ref": "#/components/schemas/OpenNc"
            }
          }
        },
        "description": "The response of checking open nonconformances for SFC."
      },
      "OpenNc": {
        "title": "Open nonconformance code and incident ID",
        "type": "object",
        "properties": {
          "ncCode": {
            "type": "string",
            "description": "The nonconformance code of the open nonconformance incident."
          },
          "incidentId": {
            "type": "string",
            "description": "The open nonconformance incident ID."
          }
        }
      },
      "NonConformanceV2": {
        "title": "NonConformance",
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "parentNcIncident": {
            "type": "string",
            "description": "The ID of the parent nonconformance incident."
          },
          "comments": {
            "type": "string"
          },
          "component": {
            "$ref": "#/components/schemas/Material"
          },
          "componentSfc": {
            "$ref": "#/components/schemas/Material"
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "fileIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "incidentNumber": {
            "$ref": "#/components/schemas/IncidentNumber"
          },
          "material": {
            "$ref": "#/components/schemas/Material"
          },
          "modifiedDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "operationActivity": {
            "$ref": "#/components/schemas/OperationActivity"
          },
          "plant": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "resource": {
            "type": "string"
          },
          "routing": {
            "$ref": "#/components/schemas/Routing"
          },
          "routingStepId": {
            "type": "string"
          },
          "sfc": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "OPEN",
              "CLOSED",
              "CANCELLED",
              "CLOSE_PENDING"
            ]
          },
          "user": {
            "type": "string"
          },
          "workCenter": {
            "type": "string"
          },
          "dataFields": {
            "type": "array",
            "description": "The data field/value pairs associated with the nonconformance.",
            "items": {
              "$ref": "#/components/schemas/DataField"
            }
          }
        },
        "description": "NonConformance Incident."
      },
      "Pageable": {
        "type": "object",
        "properties": {
          "offset": {
            "type": "integer",
            "description": "Returns the nonconformance incidents according to the pageNumber and pageSize you set",
            "format": "int64"
          },
          "pageNumber": {
            "type": "integer",
            "description": "Indicates the page from which the nonconformance incidents are retrieved.",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "description": "Specifies the number of records on one page.",
            "format": "int32"
          },
          "paged": {
            "type": "boolean",
            "description": "If set to 'true', retrieves the nonconformance incidents based on the properties you set in Pageable. If set to 'false', all nonconformance incidents are retrieved."
          },
          "sort": {
            "type": "array",
            "description": "Defines how the nonconformance incidents records are sorted.",
            "items": {
              "$ref": "#/components/schemas/Sort"
            }
          },
          "unpaged": {
            "type": "boolean",
            "description": "Indicates if the nonconformance incidents are retrieved based on the properties you set in Pageable, or they are all retrieved. The value of this field is automatically filled."
          }
        }
      },
      "Sort": {
        "type": "object",
        "properties": {
          "empty": {
            "type": "boolean",
            "description": "If the value is 'true', it indicates that no nonconformance incident is retrieved. If the value is 'false', it indicates that there are nonconformance incidents retrieved."
          },
          "sorted": {
            "type": "boolean",
            "description": "If the value is 'true', it indicates that the nonconformance incidents retrieved are sorted accordingly. If the value is 'false', it indicates that no nonconformance incidents are retrieved."
          },
          "unsorted": {
            "type": "boolean",
            "description": "If the value is 'false', it indicates that the nonconformance incidents retrieved are sorted accordingly. If the value is 'true', it indicates that no nonconformance incidents are retrieved."
          }
        }
      },
