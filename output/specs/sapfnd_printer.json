{
  "openapi": "3.0.1",
  "info": {
    "title": "Printer",
    "description": "An API that allows you to retrieve, create, update, and remove printers.",
    "version": "v1",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    }
  },
  "externalDocs": {
    "description": "Prepare for API Integration",
    "url": "https://help.sap.com/docs/sap-digital-manufacturing/operations-guide/prepare-for-api-integration"
  },
  "servers": [
    {
      "url": "https://api.{regionHost}/printer/v1",
      "description": "Base URL",
      "variables": {
        "regionHost": {
          "description": "The data center where SAP Digital Manufacturing is provisioned for your organization.",
          "enum": [
            "eu10.dmc.cloud.sap",
            "us10.dmc.cloud.sap",
            "eu20.dmc.cloud.sap",
            "us20.dmc.cloud.sap",
            "test.eu10.dmc.cloud.sap",
            "test.us10.dmc.cloud.sap",
            "test.eu20.dmc.cloud.sap",
            "test.us20.dmc.cloud.sap"
          ],
          "default": "test.eu10.dmc.cloud.sap"
        },
        "tokenHost": {
          "description": "The authentication token server where SAP Digital Manufacturing is provisioned for your organization.",
          "enum": [
            "eu10.hana.ondemand.com",
            "us10.hana.ondemand.com",
            "eu20.hana.ondemand.com",
            "us20.hana.ondemand.com"
          ],
          "default": "eu10.hana.ondemand.com"
        }
      }
    }
  ],
  "security": [
    {
      "OauthClientCredentials": []
    }
  ],
  "tags": [
    {
      "name": "Printer",
      "description": "Manages printers"
    }
  ],
  "x-sap-shortText": "Manage printers",
  "paths": {
    "/printers": {
      "get": {
        "tags": [
          "Printer"
        ],
        "summary": "Retrieves a page of printers.",
        "description": "Retrieves a page of printers or a specific printer defined in the request. If the sort parameter is not defined, the results are ordered by modified date-time in ascending order.",
        "operationId": "findPrintersUsingGET_1",
        "parameters": [
          {
            "name": "printer",
            "in": "query",
            "description": "A printer for which a request is executed.",
            "schema": {
              "type": "string",
              "maxLength": 128
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "The quantity of printer records to be returned. If it is not specified, the default value is 100. The maximum allowed value is 100.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The number of a page to be returned. The page number starts from 0. If it is not defined, the first page is returned.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "This parameter is used for sorting. To define the sorting order, use comma-separated values, like 'printer,desc'. The default sorting order is ascending. The following sorting parameters are supported: modifiedOn, createdOn, printer, description, and status.",
            "schema": {
              "type": "string"
            },
            "example": "modifiedOn,desc"
          }
        ],
        "responses": {
          "200": {
            "description": "The page of printers was returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrinterPageResponse"
                }
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": [
          {
            "OauthClientCredentials": []
          }
        ]
      },
      "post": {
        "tags": [
          "Printer"
        ],
        "summary": "Creates a printer.",
        "description": "Creates a printer by the given request.",
        "operationId": "createPrintersUsingPOST_1",
        "requestBody": {
          "description": "The request to create a printer.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PrinterCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "The printer was created."
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "If a PCo folder or a queue does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "The printer already exists.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": [
          {
            "OauthClientCredentials": []
          }
        ]
      },
      "patch": {
        "tags": [
          "Printer"
        ],
        "summary": "Updates a printer.",
        "description": "Updates a printer by the given request.",
        "operationId": "updatePrintersUsingPATCH_1",
        "requestBody": {
          "description": "The request to update a printer.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PrinterUpdateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "The printer was updated."
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "If a printer, a PCo folder, or a queue does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": [
          {
            "OauthClientCredentials": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Printer"
        ],
        "summary": "Deletes a printer",
        "description": "Deletes a printer by the given printer name.",
        "operationId": "deletePrintersUsingDELETE_1",
        "parameters": [
          {
            "name": "printer",
            "in": "query",
            "description": "A printer for deletion",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "The printer was deleted."
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "If a printer does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": [
          {
            "OauthClientCredentials": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "PrinterPageResponse": {
        "description": "The printer page response.",
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PrinterResponse"
            }
          },
          "number": {
            "type": "number",
            "format": "int32",
            "description": "The current page number."
          },
          "size": {
            "type": "number",
            "format": "int32",
            "description": "The size of the page."
          },
          "totalElements": {
            "type": "number",
            "format": "int64",
            "description": "The total number of elements."
          },
          "totalPages": {
            "type": "number",
            "format": "int32",
            "description": "The total number of pages."
          },
          "empty": {
            "type": "boolean",
            "description": "Indicates if the page is empty."
          }
        }
      },
      "PrinterResponse": {
        "description": "The printer response.",
        "type": "object",
        "properties": {
          "printer": {
            "type": "string",
            "description": "The name of the printer."
          },
          "description": {
            "type": "string",
            "description": "The description of the printer."
          },
          "cpsPluginOptions": {
            "$ref": "#/components/schemas/CpsPluginOptions"
          },
          "pcoPluginOptions": {
            "$ref": "#/components/schemas/PcoPluginOptions"
          },
          "status": {
            "type": "string",
            "description": "The status of the printer.",
            "enum": [
              "ENABLED",
              "DISABLED"
            ]
          },
          "plugin": {
            "type": "string",
            "description": "The name of the printer plugin.",
            "enum": [
              "SHARED_FOLDER_TRANSPORTER",
              "CPS_TRANSPORTER"
            ]
          },
          "createdOn": {
            "type": "string",
            "description": "The date and time when a printer was created. This is in the UTC timezone.",
            "format": "date-time",
            "example": "2025-02-14T14:00:06.000Z"
          },
          "modifiedOn": {
            "type": "string",
            "description": "The date and time when a printer was updated. This is in the UTC timezone.",
            "format": "date-time",
            "example": "2025-02-14T14:00:06.000Z"
          }
        }
      },
      "CpsPluginOptions": {
        "type": "object",
        "properties": {
          "queue": {
            "type": "string",
            "description": "The name of the print queue in the print service."
          }
        },
        "description": "The options of the SAP Print Service. Define this if the plugin is 'CPS_TRANSPORTER'."
      },
      "PcoPluginOptions": {
        "type": "object",
        "properties": {
          "folderId": {
            "maxLength": 36,
            "minLength": 1,
            "type": "string",
            "description": "The ID of the folder configuration in SAP Plant Connectivity."
          }
        },
        "description": "The options of SAP Plant Connectivity. Define this if the plugin is 'SHARED_FOLDER_TRANSPORTER'."
      },
      "PrinterCreateRequest": {
        "required": [
          "plugin",
          "printer"
        ],
        "type": "object",
        "properties": {
          "printer": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string",
            "description": "The name of the printer."
          },
          "description": {
            "maxLength": 40,
            "minLength": 1,
            "type": "string",
            "description": "The description of the printer."
          },
          "cpsPluginOptions": {
            "$ref": "#/components/schemas/CpsPluginOptions"
          },
          "pcoPluginOptions": {
            "$ref": "#/components/schemas/PcoPluginOptions"
          },
          "status": {
            "type": "string",
            "description": "The status of the printer.",
            "enum": [
              "ENABLED",
              "DISABLED"
            ]
          },
          "plugin": {
            "type": "string",
            "description": "The name of the printer plugin. Depending on the plugin, the options must be defined. If the plugin is 'CPS_TRANSPORTER', the 'cpsPluginOptions' must be defined. If the plugin is 'SHARED_FOLDER_TRANSPORTER', the 'pcoPluginOptions' must be defined.",
            "enum": [
              "SHARED_FOLDER_TRANSPORTER",
              "CPS_TRANSPORTER"
            ]
          }
        },
        "description": "Create a printer request."
      },
      "PrinterUpdateRequest": {
        "required": [
          "modifiedOn",
          "printer"
        ],
        "type": "object",
        "properties": {
          "printer": {
            "maxLength": 128,
            "minLength": 1,
            "type": "string",
            "description": "The name of the printer."
          },
          "description": {
            "maxLength": 40,
            "minLength": 1,
            "type": "string",
            "description": "The description of the printer."
          },
          "cpsPluginOptions": {
            "$ref": "#/components/schemas/CpsPluginOptions"
          },
          "pcoPluginOptions": {
            "$ref": "#/components/schemas/PcoPluginOptions"
          },
          "status": {
            "type": "string",
            "description": "The status of the printer.",
            "enum": [
              "ENABLED",
              "DISABLED"
            ]
          },
          "plugin": {
            "type": "string",
            "description": "The name of the printer plugin. Depending on the plugin, the options must be defined. If the plugin is 'CPS_TRANSPORTER', the 'cpsPluginOptions' must be defined. If the plugin is 'SHARED_FOLDER_TRANSPORTER', the 'pcoPluginOptions' must be defined.",
            "enum": [
              "SHARED_FOLDER_TRANSPORTER",
              "CPS_TRANSPORTER"
            ]
          },
          "modifiedOn": {
            "type": "string",
            "description": "The date and time when a printer was updated. This is in the UTC timezone.",
            "format": "date-time",
            "example": "2025-02-14T14:00:06.000Z"
          }
        },
        "description": "Update a printer request."
      },
      "ErrorResponse": {
        "description": "The error response.",
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "The error message."
              },
              "code": {
                "type": "string",
                "description": "The HTTP status code."
              },
              "correlationId": {
                "type": "string",
                "description": "Contains the correlation ID for the error."
              },
              "details": {
                "type": "array",
                "description": "Details of the exception.",
                "items": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "description": "The internal error code."
                    },
                    "message": {
                      "type": "string",
                      "description": "The message that describes the error."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "OauthClientCredentials": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{subdomain}.authentication.{regionHost}/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  }
}