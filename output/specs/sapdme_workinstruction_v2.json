          "routing": {
            "type": "string",
            "description": "The name of the routing or recipe."
          },
          "routingType": {
            "type": "string",
            "description": "Indicates the type of routing or recipe.",
            "enum": [
              "PRODUCTION",
              "NC",
              "SPECIAL",
              "DISPOSITION_FUNCTION",
              "SFC_SPECIFIC",
              "SHOPORDER_SPECIFIC",
              "CONFIGURABLE",
              "PRODUCTION_RECIPE",
              "SHOPORDER_SPECIFIC_RECIPE",
