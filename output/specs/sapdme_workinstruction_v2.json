{
  "openapi": "3.0.1",
  "info": {
    "title": "Work Instruction",
    "description": "Work instruction is an electronic document containing information about how to perform a task, used by operators on the shop floor. This API provides functionality to create Work Instruction business object.",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    },
    "version": "v2"
  },
  "x-sap-shortText": "Use this API to manage work instructions in SAP Digital Manufacturing.",
  "externalDocs": {
    "description": "Prepare for API Integration",
    "url": "https://help.sap.com/docs/sap-digital-manufacturing/operations-guide/prepare-for-api-integration"
  },
  "servers": [
    {
      "url": "https://api.{regionHost}/workinstruction/v2",
      "description": "Base URL",
      "variables": {
        "regionHost": {
          "description": "The data center where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.dmc.cloud.sap",
            "eu20.dmc.cloud.sap",
            "us10.dmc.cloud.sap",
            "us20.dmc.cloud.sap",
            "test.eu10.dmc.cloud.sap",
            "test.eu20.dmc.cloud.sap",
            "test.us10.dmc.cloud.sap",
            "test.us20.dmc.cloud.sap"
          ],
          "default": "test.eu10.dmc.cloud.sap"
        },
        "tokenHost": {
          "description": "The authentication server where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.hana.ondemand.com",
            "eu20.hana.ondemand.com",
            "us10.hana.ondemand.com",
            "us20.hana.ondemand.com"
          ],
          "default": "eu10.hana.ondemand.com"
        }
      }
    }
  ],
  "security": [
    {
      "OauthClientCredentials": []
    }
  ],
  "tags": [
    {
      "name": "Work Instructions",
      "description": "Allows you to interact with work instructions."
    }
  ],
  "paths": {
    "/workinstructions": {
      "post": {
        "tags": [
          "Work Instructions"
        ],
        "summary": "Creates a list of work instructions for the given plant.",
        "description": "Creates a work instruction which can be attached to other objects like a material, resource, order and work center.",
        "requestBody": {
          "description": "The list of work instructions to create.",
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/WorkInstruction"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Message successfully processed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WorkInstruction"
                  }
                }
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "One of the related elements is not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "The work instruction already exists.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": [
          {
            "OAuthSecurity": []
          }
        ],
        "x-codegen-request-body-name": "workInstructionList"
      }
    },
    "/findAttachedWorkInstructions": {
      "post": {
        "tags": [
          "Work Instructions"
        ],
        "summary": "Find attached work instructions by provided context.",
        "description": "Retrieves the list of work instructions based on provided context parameters, such as material, routing, routing activity, order, operation activity, resource, and work center.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Zero-based page index (0..N).",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "The size of the page to be returned. Default - 50. Maximum size - 200.",
            "schema": {
              "maximum": 200,
              "type": "integer",
              "default": 50
            }
          }
        ],
        "requestBody": {
          "description": "The request containing the manufacturing context to search for attached work instructions.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindAttachedWorkInstructionsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Message successfully processed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedFindAttachedWorkInstructionsResponse"
                }
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseV2"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseV2"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseV2"
                }
              }
            }
          },
          "404": {
            "description": "One of the related elements is not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseV2"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponseV2"
                }
              }
            }
          }
        },
        "deprecated": false,
        "security": [
          {
            "OAuthSecurity": []
          }
        ],
        "x-codegen-request-body-name": "request"
      }
    }
  },
