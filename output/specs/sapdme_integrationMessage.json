{
  "openapi": "3.0.1",
  "info": {
    "title": "Integration Messages",
    "description": "Allows you to interact with integration messages in Integration Message Dashboard application. You can use this service to search and view integration messages. You can also set the indicated integration messages to inactive.",
    "version": "v1",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    }
  },
  "externalDocs": {
    "description": "Prepare for API Integration",
    "url": "https://help.sap.com/docs/sap-digital-manufacturing/operations-guide/prepare-for-api-integration"
  },
  "security": [
    {
      "OauthClientCredentials": []
    }
  ],
  "tags": [
    {
      "name": "Integration Messages"
    }
  ],
  "paths": {
    "/v1/integrationMessages": {
      "get": {
        "tags": [
          "Integration Messages"
        ],
        "summary": "Finds integration messages.",
        "description": "Finds integration messages for given plants, message types, overall statuses, Created On, and Last Updated On.",
        "operationId": "list",
        "parameters": [
          {
            "name": "plants",
            "in": "query",
            "description": "Filter for plants.",
            "required": false,
            "schema": {
              "type": "array",
              "description": "Filter for plants.",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "messageTypes",
            "in": "query",
            "description": "Filter for message types.",
            "required": false,
            "schema": {
              "type": "array",
              "description": "Filter for message types.",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "overallStatuses",
            "in": "query",
            "description": "Filter for overall statuses.",
            "required": false,
            "schema": {
              "type": "array",
              "description": "Filter for overall statuses.",
              "items": {
                "type": "string",
                "enum": [
                  "NEW",
                  "QUEUED",
                  "FAILED_BEFORE_QUEUE",
                  "IN_PROCESS",
                  "DELIVERED",
                  "COMPLETED",
                  "FAILED",
                  "INACTIVE"
                ]
              }
            }
          },
          {
            "name": "createdOnFrom",
            "in": "query",
            "description": "Filter for Created On with a start date.",
            "example": "2023-12-11T05:26:20.963Z",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "createdOnTo",
            "in": "query",
            "description": "Filter for Created On with an end date.",
            "example": "2023-12-11T05:26:20.963Z",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "lastUpdatedOnFrom",
            "in": "query",
            "description": "Filter for Last Updated On with a start date.",
            "example": "2023-12-11T05:26:20.963Z",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "lastUpdatedOnTo",
            "in": "query",
            "description": "Filter for Last Updated On with an end date.",
            "example": "2023-12-11T05:26:20.963Z",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page",
            "required": false,
            "schema": {
              "minimum": 0,
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Size",
            "required": false,
            "schema": {
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [
                "startedAt,DESC"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Integration messages have been retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageFindIntegrationMessageResponse"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnAuthErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnAuthErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "There was an internal error somewhere in the call chain.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/integrationMessages/setToInactive": {
      "post": {
        "tags": [
          "Integration Messages"
        ],
        "summary": "Set the indicated integration messages to inactive.",
        "description": "Set the indicated integration messages to inactive for the given IDs of integration messages.",
        "operationId": "setToInactive",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "description": "The list of the IDs of the integration messages that should be set to inactive.",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "The indicated integration messages have been set to inactive in the Integration Message Dashboard.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "description": "The list of the IDs of the integration messages that have been set to inactive in the Integration Message Dashboard.",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "The HTTP request is bad or invalid and cannot be processed by the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "You are not authorized to call this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnAuthErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Accessing the resource you are trying to reach is forbidden.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnAuthErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "There was an internal error somewhere in the call chain.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UnAuthErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Contains additional information."
          },
          "code": {
            "type": "string",
            "description": "Internal error message."
          },
          "causeMessage": {
            "type": "string",
            "description": "Contains technical reason for the error."
          }
        },
        "description": "Error response."
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Contains additional information."
          },
          "code": {
            "type": "string",
            "description": "Internal error message."
          },
          "causeMessage": {
            "type": "string",
            "description": "Contains technical reason for the error."
          },
          "correlationId": {
            "type": "string",
            "description": "Contains correlationId for the error."
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code",
            "format": "int32"
          }
        },
        "description": "Error response."
      },
      "FindIntegrationMessageResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The ID of the integration message"
          },
          "plant": {
            "type": "string",
            "description": "The plant of the integration message"
          },
          "messageNumber": {
            "type": "string",
            "description": "The message number of the integration message"
          },
          "messageType": {
            "type": "string",
            "description": "The message type of the integration message"
          },
          "overallStatus": {
            "type": "string",
            "description": "The overall status of the integration message"
          }
        },
        "description": "This object represents the integration message."
      },
      "PageFindIntegrationMessageResponse": {
        "type": "object",
        "properties": {
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "totalElements": {
            "type": "integer",
            "format": "int64"
          },
          "pageable": {
            "$ref": "#/components/schemas/PageableObject"
          },
          "numberOfElements": {
            "type": "integer",
            "format": "int32"
          },
          "first": {
            "type": "boolean"
          },
          "last": {
            "type": "boolean"
          },
          "number": {
            "type": "integer",
            "format": "int32"
          },
          "sort": {
            "$ref": "#/components/schemas/SortObject"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FindIntegrationMessageResponse"
            }
          },
          "empty": {
            "type": "boolean"
          }
        }
      },
      "PageableObject": {
        "type": "object",
        "properties": {
          "pageNumber": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "paged": {
            "type": "boolean"
          },
          "unpaged": {
            "type": "boolean"
          },
          "sort": {
            "$ref": "#/components/schemas/SortObject"
          },
          "offset": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "SortObject": {
        "type": "object",
        "properties": {
          "sorted": {
            "type": "boolean"
          },
          "unsorted": {
            "type": "boolean"
          },
          "empty": {
            "type": "boolean"
          }
        }
      }
    },
    "securitySchemes": {
      "OauthClientCredentials": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{subdomain}.authentication.{tokenHost}/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "x-sap-shortText": "Interact with integration messages in the Manage Integration Dashboard.",
  "servers": [
    {
      "url": "https://api.{regionHost}/integration",
      "description": "Base URL",
      "variables": {
        "regionHost": {
          "description": "The data center where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.dmc.cloud.sap",
            "eu20.dmc.cloud.sap",
            "us10.dmc.cloud.sap",
            "us20.dmc.cloud.sap",
            "test.eu10.dmc.cloud.sap",
            "test.eu20.dmc.cloud.sap",
            "test.us10.dmc.cloud.sap",
            "test.us20.dmc.cloud.sap"
          ],
          "default": "test.eu10.dmc.cloud.sap"
        },
        "tokenHost": {
          "description": "The authentication server where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.hana.ondemand.com",
            "eu20.hana.ondemand.com",
            "us10.hana.ondemand.com",
            "us20.hana.ondemand.com"
          ],
          "default": "eu10.hana.ondemand.com"
        }
      }
    }
  ]
}