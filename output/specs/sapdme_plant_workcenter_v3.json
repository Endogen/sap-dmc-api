      "ResourceId": {
        "title": "ResourceId",
        "description": "Resource identifier.",
        "type": "object",
        "required": [
          "plant",
          "resource"
        ],
        "properties": {
          "plant": {
            "type": "string",
            "pattern": "^(?! )[0-9A-Z_$!)(+~@^=\\-*. ]+(?<! )$"
          },
          "resource": {
            "type": "string",
            "pattern": "^(?! )[0-9A-Z_$!)(+~@^=\\-*. ]+(?<! )$"
          }
        }
      },
      "WorkCenterId": {
        "title": "WorkCenterId",
        "description": "The work center identifier.",
        "type": "object",
        "required": [
          "plant",
          "workcenter"
        ],
        "properties": {
          "plant": {
            "type": "string"
          },
          "work\u0421enter": {
            "type": "string"
          }
        }
      },
      "CustomValue": {
        "title": "CustomValue",
        "description": "Custom value",
        "type": "object",
        "properties": {
          "attribute": {
