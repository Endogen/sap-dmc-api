            "pattern": "^(?! )[0-9A-Z_$!)(+~@^=\\-*. ]+(?<! )$"
          },
          "workCenter": {
            "type": "string",
            "description": "The work center value.",
            "pattern": "^(?! )[0-9A-Z_$!)(+~@^=\\-*. ]+(?<! )$"
          },
          "status": {
