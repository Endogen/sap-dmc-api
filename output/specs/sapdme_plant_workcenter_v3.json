      "UserAssignmentId": {
        "title": "UserAssignmentId",
        "description": "The user unique data.",
        "type": "object",
        "required": [
          "plant",
          "userId"
        ],
        "properties": {
          "plant": {
            "type": "string",
            "description": "The plant where a user is created.",
            "pattern": "^(?! )[0-9A-Z_$!)(+~@^=\\-*. ]+(?<! )$"
          },
          "userId": {
            "type": "string",
