{
  "openapi": "3.0.2",
  "info": {
    "title": "Data Type",
    "description": "This API allows you to create, update, retrieve, and delete data types in SAP Digital Manufacturing.",
    "version": "v1",
    "contact": {
      "name": "SAP Digital Manufacturing Operations",
      "email": "sap-dmoperation@sap.com"
    }
  },
  "x-sap-shortText": "Create, update, retrieve, and delete data types.",
  "externalDocs": {
    "description": "Prepare for API Integration",
    "url": "https://help.sap.com/docs/sap-digital-manufacturing/operations-guide/prepare-for-api-integration"
  },
  "servers": [
    {
      "url": "https://api.{regionHost}/dataType",
      "description": "Base URL",
      "variables": {
        "regionHost": {
          "description": "The data center where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.dmc.cloud.sap",
            "eu20.dmc.cloud.sap",
            "us10.dmc.cloud.sap",
            "us20.dmc.cloud.sap",
            "test.eu10.dmc.cloud.sap",
            "test.eu20.dmc.cloud.sap",
            "test.us10.dmc.cloud.sap",
            "test.us20.dmc.cloud.sap"
          ],
          "default": "test.eu10.dmc.cloud.sap"
        },
        "tokenHost": {
          "description": "The authentication server where SAP Digital Manufacturing is provisioned for your organization",
          "enum": [
            "eu10.hana.ondemand.com",
            "eu20.hana.ondemand.com",
            "us10.hana.ondemand.com",
            "us20.hana.ondemand.com"
          ],
          "default": "eu10.hana.ondemand.com"
        }
      }
    }
  ],
  "security": [
    {
      "OauthClientCredentials": []
    }
  ],
  "tags": [
    {
      "name": "Data Type"
    }
  ],
  "paths": {
    "/v1/dataTypes": {
      "get": {
        "tags": [
          "Data Type"
        ],
        "summary": "Gets paginated list of data types by plant and optional search parameters",
        "description": "Retrieves a paginated list of data types for a specific plant with optional filtering by category and data type name",
        "operationId": "getDataTypes",
        "parameters": [
          {
            "name": "plant",
            "in": "query",
            "description": "Plant identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Data Type category",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "ASSEMBLY",
                "NC",
                "PACKING_CONTAINER",
                "PACKING_SFC",
                "RMA_SFC",
                "RMA_SHOP_ORDER",
                "SFC"
              ]
            }
          },
          {
            "name": "dataType",
            "in": "query",
            "description": "Data Type name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "A zero-based page index (0..N)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0,
              "minimum": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "The size of the page to be returned. Maximum size - 100.",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort criteria according to the format: property,(asc|desc). Multiple sort criteria are supported. Allowed sort fields: dataType, category.",
            "example": "sort=dataType,asc",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": [
                "dataType,asc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message processed successfully. The system returns a pageable collection of data types.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageDataTypeResponse"
                }
              }
            }
          },
          "400": {
            "description": "The request is invalid or malformed and cannot be processed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication is required to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "You don't have permission to access this resource",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "The requested resource doesn't exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Something went wrong on the server side.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Data Type"
        ],
        "summary": "Creates a list of data types",
        "description": "Creates multiple data type objects",
        "operationId": "createDataTypes",
        "requestBody": {
          "description": "A list of data types to create",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DataTypeRequest"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "A new resource was successfully created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataTypeResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "The request is invalid or malformed and cannot be processed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication is required to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "You don't have permission to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "The requested resource doesn't exist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "There's a conflict with the current state.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Something went wrong on the server side.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Data Type"
        ],
        "summary": "Updates a list of data types",
        "description": "Updates one or more data type objects. Only provided fields are updated.",
        "operationId": "updateDataTypes",
        "requestBody": {
          "description": "List of data types to update",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DataTypeRequest"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The request was successful and the message was processed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataTypeResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "The request is invalid or malformed and cannot be processed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication is required to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "You don't have permission to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "The requested resource doesn't exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Something went wrong on the server side.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Data Type"
        ],
        "summary": "Deletes a data type by plant, data type name, and category",
        "description": "Deletes a data type by plant, data type name, and category. Only data types with an empty data field list can be deleted.",
        "operationId": "deleteDataType",
        "parameters": [
          {
            "name": "plant",
            "in": "query",
            "description": "Plant identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Data Type category",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "ASSEMBLY",
                "NC",
                "PACKING_CONTAINER",
                "PACKING_SFC",
                "RMA_SFC",
                "RMA_SHOP_ORDER",
                "SFC"
              ]
            }
          },
          {
            "name": "dataType",
            "in": "query",
            "description": "Data Type name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "The request was successful but there's no content to return."
          },
          "400": {
            "description": "The request is invalid or malformed and cannot be processed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication is required to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "You don't have permission to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "The requested resource doesn't exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Something went wrong on the server side.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DataTypeRequest": {
        "type": "object",
        "required": [
          "plant",
          "dataType",
          "category"
        ],
        "properties": {
          "plant": {
            "type": "string",
            "description": "The plant this data type is assigned to",
            "example": "PLANT01"
          },
          "dataType": {
            "type": "string",
            "description": "Name of the data type",
            "example": "ASSEMBLY_DATA_TYPE"
          },
          "category": {
            "type": "string",
            "description": "Category of the data type",
            "enum": [
              "ASSEMBLY",
              "NC",
              "PACKING_CONTAINER",
              "PACKING_SFC",
              "RMA_SFC",
              "RMA_SHOP_ORDER",
              "SFC"
            ],
            "example": "ASSEMBLY"
          },
          "description": {
            "type": "string",
            "description": "Description of the data type",
            "example": "A custom data type for tracking assembly information."
          },
          "dataFieldList": {
            "type": "array",
            "description": "A list of the data fields associated with this data type",
            "items": {
              "$ref": "#/components/schemas/DataTypeFieldBasic"
            },
            "example": [
              {
                "dataField": {
                  "fieldName": "ASSEMBLY_COLOR"
                },
                "sequence": 1,
                "required": true
              },
              {
                "dataField": {
                  "fieldName": "ASSEMBLY_SIZE"
                },
                "sequence": 2,
                "required": false
              }
            ]
          }
        }
      },
      "DataTypeResponse": {
        "type": "object",
        "properties": {
          "plant": {
            "type": "string",
            "description": "The plant this data type is assigned to"
          },
          "dataType": {
            "type": "string",
            "description": "Name of the data type"
          },
          "category": {
            "type": "string",
            "enum": [
              "ASSEMBLY",
              "NC",
              "PACKING_CONTAINER",
              "PACKING_SFC",
              "RMA_SFC",
              "RMA_SHOP_ORDER",
              "SFC"
            ],
            "description": "Category of the data type"
          },
          "description": {
            "type": "string",
            "description": "Description of the data type"
          },
          "dataFieldList": {
            "type": "array",
            "description": "A list of data fields associated with this data type",
            "items": {
              "$ref": "#/components/schemas/DataTypeField"
            }
          },
          "createdDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time when the data type was created"
          },
          "modifiedDateTime": {
            "type": "string",
            "format": "date-time",
            "description": "The date and time when the data type was last modified"
          }
        }
      },
      "DataTypeFieldBasic": {
        "type": "object",
        "required": [
          "dataField",
          "sequence"
        ],
        "properties": {
          "dataField": {
            "$ref": "#/components/schemas/DataFieldBasic"
          },
          "sequence": {
            "type": "integer",
            "format": "int64",
            "description": "The sequence number of this data type field",
            "example": 1
          },
          "required": {
            "type": "boolean",
            "description": "If true, then this field is required",
            "example": true
          }
        }
      },
      "DataTypeField": {
        "type": "object",
        "properties": {
          "dataField": {
            "$ref": "#/components/schemas/DataField"
          },
          "sequence": {
            "type": "integer",
            "format": "int64",
            "description": "The sequence number of this data type field",
            "example": 1
          },
          "required": {
            "type": "boolean",
            "description": "If true, then this field is required",
            "example": true
          }
        }
      },
      "DataFieldBasic": {
        "type": "object",
        "required": [
          "fieldName"
        ],
        "properties": {
          "fieldName": {
            "type": "string",
            "description": "The name of the data field. Must reference an existing data field.",
            "example": "ASSEMBLY_COLOR"
          }
        }
      },
      "DataField": {
        "type": "object",
        "properties": {
          "fieldName": {
            "type": "string",
            "description": "The name of the data field"
          },
          "fieldLabel": {
            "type": "string",
            "description": "The label of the data field"
          },
          "description": {
            "type": "string",
            "description": "The description of the data field"
          },
          "type": {
            "type": "string",
            "enum": [
              "TEXT",
              "TEXT_AREA",
              "DATE",
              "NUMBER",
              "CHECKBOX",
              "LIST",
              "FORMULA"
            ],
            "description": "The type of the data field"
          },
          "dataFieldOptions": {
            "type": "array",
            "description": "The options of the data field for LIST type fields",
            "items": {
              "$ref": "#/components/schemas/DataFieldOption"
            }
          },
          "status": {
            "type": "string",
            "description": "The status of the data field"
          },
          "browsable": {
            "type": "boolean",
            "description": "Defines whether this data field is browsable"
          },
          "plant": {
            "type": "string",
            "description": "The plant of the data field"
          }
        }
      },
      "DataFieldOption": {
        "type": "object",
        "properties": {
          "fieldValue": {
            "type": "string",
            "description": "The value of the option."
          },
          "optionLabel": {
            "type": "string",
            "description": "The label for the option."
          },
          "isDefault": {
            "type": "boolean",
            "description": "Indicates if this option is the default."
          }
        }
      },
      "PageDataTypeResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataTypeResponse"
            }
          },
          "pageable": {
            "$ref": "#/components/schemas/PageableObject"
          },
          "last": {
            "type": "boolean",
            "description": "True if it is the last page"
          },
          "totalElements": {
            "type": "integer",
            "description": "The total number of records that are retrieved"
          },
          "totalPages": {
            "type": "integer",
            "description": "The total number of pages returned"
          },
          "size": {
            "type": "integer",
            "description": "The page size"
          },
          "number": {
            "type": "integer",
            "description": "The page number"
          },
          "sort": {
            "$ref": "#/components/schemas/SortObject"
          },
          "first": {
            "type": "boolean",
            "description": "True if it is the first page"
          },
          "numberOfElements": {
            "type": "integer",
            "description": "The number of elements in the current page"
          },
          "empty": {
            "type": "boolean",
            "description": "Returns true if the result is empty"
          }
        }
      },
      "ErrorResponse": {
        "title": "ErrorResponse",
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Contains a technical code for the error."
          },
          "correlationId": {
            "type": "string",
            "description": "Contains a correlation ID for the error."
          },
          "message": {
            "type": "string",
            "description": "Error message."
          },
          "details": {
            "type": "array",
            "description": "Error message details.",
            "items": {
              "$ref": "#/components/schemas/ErrorDetail"
            }
          }
        }
      },
      "ErrorDetail": {
        "title": "ErrorDetail",
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Contains a technical code for the error."
          },
          "message": {
            "type": "string",
            "description": "Contains a detailed message for the error."
          }
        },
        "description": "Error detail."
      },
      "PageableObject": {
        "type": "object",
        "properties": {
          "pageNumber": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          },
          "sort": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SortObject"
            }
          },
          "offset": {
            "type": "integer"
          },
          "paged": {
            "type": "boolean"
          },
          "unpaged": {
            "type": "boolean"
          }
        }
      },
      "SortObject": {
        "type": "object",
        "properties": {
          "direction": {
            "type": "string"
          },
          "property": {
            "type": "string"
          },
          "ignoreCase": {
            "type": "boolean"
          },
          "nullHandling": {
            "type": "string"
          },
          "descending": {
            "type": "boolean"
          },
          "ascending": {
            "type": "boolean"
          }
        }
      }
    },
    "securitySchemes": {
      "OauthClientCredentials": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{subdomain}.authentication.{tokenHost}/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  }
}