  "definitions": {
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "causeMessage": {
          "type": "string",
          "description": "Contains a technical reason for the error."
        },
        "code": {
          "type": "string",
          "description": "Internal error message"
        },
        "correlationId": {
          "type": "string",
          "description": "Contains correlationId for the error."
        },
        "message": {
          "type": "string",
          "description": "Contains additional information, if any"
        },
        "status": {
          "type": "integer",
          "format": "int32",
          "description": "HTTP status code"
        }
      },
      "title": "ErrorResponse",
      "description": "Error response."
    },
    "UpdateProcessLotRequest": {
      "type": "object",
      "required": [
        "number",
        "plant"
      ],
      "properties": {
        "plant": {
          "type": "string",
          "description": "The Plant where the Process Lot is used."
        },
        "number": {
          "type": "string",
          "description": "The Process Lot Number for the Plant."
        },
        "members": {
          "type": "array",
          "description": "The Members of the Process Lot.",
          "items": {
            "$ref": "#/definitions/ProcessLotMemberApiModel"
          }
        }
      },
      "title": "UpdateProcessLotRequest"
    },
    "ProcessLotApiModel": {
      "type": "object",
      "properties": {
        "plant": {
          "type": "string",
          "description": "The Plant where the Process Lot is used."
        },
        "number": {
          "type": "string",
          "description": "The Process Lot Number for the Plant."
        },
        "members": {
          "type": "array",
          "description": "The Members of the Process Lot.",
          "items": {
            "$ref": "#/definitions/ProcessLotMemberApiModel"
          }
        },
        "modifiedDateTime": {
          "type": "string",
          "format": "date-time",
          "example": "2021-09-08T13:50:45.751+00:00",
          "description": "The time when the Process Lot was updated."
        }
      },
      "title": "ProcessLotApiModel",
      "description": "The object that represents the Process Lot."
    },
    "ProcessLotMemberApiModel": {
      "type": "object",
      "properties": {
        "processLot": {
          "description": "The Process Lot which is the content of a Process Lot.",
          "$ref": "#/definitions/ProcessLot"
        },
        "sfc": {
          "description": "The SFC which is the content of a Process Lot.",
          "$ref": "#/definitions/SFC"
        }
      },
      "title": "ProcessLotMemberApiModel"
    },
    "SFC": {
      "type": "object",
      "required": [
        "sfc",
        "plant"
      ],
      "properties": {
        "plant": {
          "type": "string",
          "description": "The Plant of the SFC."
        },
        "sfc": {
          "type": "string",
          "description": "The name of the SFC."
        }
      },
      "title": "SFC"
    },
    "ProcessLot": {
      "type": "object",
      "required": [
        "number",
        "plant"
      ],
      "properties": {
        "plant": {
          "type": "string",
          "description": "The Plant where the Process Lot is used."
        },
        "number": {
          "type": "string",
          "description": "The Process Lot Number for the Plant."
        },
        "members": {
          "type": "array",
          "description": "The Members of the Process Lot. The Members of the Process Lot can include another Process Lot or an SFC.",
          "items": {
            "$ref": "#/definitions/ProcessLotMemberApiModel"
          }
        }
      },
      "title": "ProcessLot"
    },
    "ProcessLotStart": {
      "type": "object",
      "required": [
        "plant",
        "operation",
        "resource",
        "processLot"
      ],
      "properties": {
        "plant": {
          "type": "string",
          "description": "The Plant where the Process Lot is used."
        },
        "operation": {
          "type": "string",
          "description": "The operation on which all SFCs of process lot need to be start."
        },
        "resource": {
          "type": "string",
          "description": "The resource used to start all SFCs of process lot."
        },
        "quantity": {
          "type": "string",
          "description": "The quantity used to start all SFCs of process lot."
        },
        "processLot": {
          "type": "string",
          "description": "Process Lot name to find SFCs and start them."
        }
      },
      "title": "ProcessLotStart"
    },
    "ProcessLotComplete": {
      "type": "object",
      "required": [
        "plant",
        "operation",
        "resource",
        "processLot"
      ],
      "properties": {
        "plant": {
          "type": "string",
          "description": "The Plant where the Process Lot is used."
        },
        "operation": {
          "type": "string",
          "description": "The operation on which all SFCs of process lot need to be completed."
        },
        "resource": {
          "type": "string",
          "description": "The resource used to complete all SFCs of process lot."
        },
        "quantity": {
          "type": "string",
          "description": "The quantity used to complete all SFCs of process lot."
        },
        "processLot": {
          "type": "string",
          "description": "Process Lot name to find SFCs and complete them."
        }
      },
      "title": "ProcessLotComplete"
    },
    "ProcessLotStartResponse": {
      "type": "object",
      "properties": {
        "sfcs": {
          "type": "array",
          "description": "The list of started SFCs.",
          "items": {
            "type": "string"
          },
          "maxItems": 500
        }
      },
      "title": "StartSfcResponse",
      "description": "The SFC start response."
    },
    "ProcessLotCompleteResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "description": "A boolean value that indicates if the Complete is successful."
        },
        "sfcs": {
          "type": "array",
          "description": "The list of completed SFCs.",
          "items": {
            "type": "string"
          },
          "maxItems": 500
        },
        "queuedOperations": {
          "type": "array",
          "description": "Operations where SFCs are queued at",
          "items": {
            "type": "string"
          },
          "maxItems": 500
        },
        "scrapped": {
          "type": "boolean",
          "description": "A boolean value that indicates if the SFC is scrapped"
        },
        "buyoffs": {
          "type": "array",
          "description": "List of open buyoffs",
          "items": {
            "type": "string"
          },
          "maxItems": 500
        },
        "doneStatuses": {
          "type": "array",
          "description": "List of SFCs and their done status.",
          "items": {
            "$ref": "#/definitions/SfcDoneStatus"
          },
          "maxItems": 500
        }
      },
      "title": "ProcessLotCompleteResponse",
      "description": "The Process Lot Complete response."
    },
    "SfcDoneStatus": {
      "type": "object",
      "properties": {
        "sfc": {
          "type": "string",
          "description": "The SFC for this status."
        },
        "done": {
          "type": "boolean",
          "description": "A boolean value that indicates if SFC is done or not."
        }
      },
      "title": "SfcDoneStatus",
      "description": "The done status for an SFC."
    }
  },
